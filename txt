service cloud.firestore {
  match /databases/{database}/documents {
  
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
      
    match /notes/{noteId} {
      // Allow read if the user ID in the document matches the authenticated user
      // or if the document ID starts with the user's ID
      allow read: if request.auth != null && 
                  (resource.data.userId == request.auth.uid || 
                   noteId.matches(request.auth.uid + '_.*'));
      
      // Allow create if the user is authenticated and setting their own user ID
      allow create: if request.auth != null && 
                    request.resource.data.userId == request.auth.uid &&
                    noteId.matches(request.auth.uid + '_.*');
      
      // Allow update if the user is authenticated and not changing the user ID or videoId
      allow update: if request.auth != null && 
                    resource.data.userId == request.auth.uid &&
                    request.resource.data.userId == request.auth.uid &&
                    resource.data.videoId == request.resource.data.videoId;
      
      // Allow delete only for the user's own notes
      allow delete: if request.auth != null && 
                    resource.data.userId == request.auth.uid;
    }
    
    // Helper function to check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Match quizAttempts collection - stores the score and attempt status
    match /quizAttempts/{docId} {
      // Allow read if the user is signed in and the document belongs to them
      // Document ID format: {userId}_{videoId}
      allow read: if isSignedIn() && docId.split('_')[0] == request.auth.uid;
      
      // Allow create only if:
      // 1. User is signed in
      // 2. Document ID starts with their user ID
      // 3. The user ID in the data matches their auth ID
      allow create: if request.auth != null && 
                    docId.split('_')[0] == request.auth.uid &&
                    request.resource.data.userId == request.auth.uid;
    }
    
    // Match quizData collection - stores questions and user answers
    match /quizData/{docId} {
      // Allow read if the user is signed in and the document belongs to them
      allow read: if request.auth != null && docId.split('_')[0] == request.auth.uid;
      
      // Allow create only for the user's own data
      allow create: if request.auth != null && 
                    docId.split('_')[0] == request.auth.uid &&
                    request.resource.data.userId == request.auth.uid;
                    
                    
                    
    }
  }
}



