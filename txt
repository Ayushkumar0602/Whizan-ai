      allow create: if isUserData(request.resource.data.userId) &&
                    docId.matches(request.auth.uid + '_.*') &&
                    isValidQuizAttempt();
      
      // Prevent updates/deletes to maintain history integrity
      allow update, delete: if false;
    }
    
    // QuizData collection
    match /quizData/{docId} {
      allow read: if isUserData(resource.data.userId) || 
                   isUserData(docId.split('_')[0]);
      
      allow create: if isUserData(request.resource.data.userId) &&
                    docId.matches(request.auth.uid + '_.*') &&
                    request.resource.data.keys().hasAll(['questions', 'userAnswers']);
      
      allow update, delete: if false;
