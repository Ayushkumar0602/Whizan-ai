{
  "rules": {
    "course_chats": {
      "$courseId": {
        ".read": "auth !== null",
        
        "messages": {
          ".read": "auth !== null",
          ".write": "auth !== null",
          "$messageId": {
            ".validate": "newData.hasChildren(['text', 'senderId', 'timestamp'])",
            ".write": "auth !== null && (auth.uid === data.child('senderId').val() || !data.exists())",
            
            "text": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length < 1000"
            },
            "senderId": {
              ".validate": "newData.isString() && newData.val() === auth.uid"
            },
            "timestamp": {
              ".validate": "newData.isNumber() && newData.val() <= now"
            },
            "pinned": {
              ".validate": "newData.isBoolean()"
            },
            "urls": {
              ".validate": "newData.isString() || (newData.hasChildren() && newData.val().length <= 3)"
            },
            "reactions": {
              "$userId": {
                ".write": "auth !== null && auth.uid === $userId",
                ".validate": "newData.isString() && newData.val().length <= 2"
              }
            },
            "views": {
              "$userId": {
                ".write": "auth !== null && auth.uid === $userId",
                ".validate": "newData.isBoolean()"
              }
            }
          }
        },
        
        "typing": {
          ".read": "auth !== null",
          "$userId": {
            ".write": "auth !== null && auth.uid === $userId",
            ".validate": "newData.isBoolean()"
          }
        },
        
        "online": {
          ".read": "auth !== null",
          "$userId": {
            ".write": "auth !== null && auth.uid === $userId",
            ".validate": "newData.isBoolean()"
          }
        },
        
        "last_read": {
          "$userId": {
            ".write": "auth !== null && auth.uid === $userId",
            ".validate": "newData.isNumber() && newData.val() <= now"
          }
        }
      }
    },
    
    "indexes": {
      "course_chats": {
        "$courseId": {
          "messages": {
            "pinned": {
              ".indexOn": ".value"
            },
            "timestamp": {
              ".indexOn": ".value"
            }
          }
        }
      }
    },
    
    "resumes": {
      "$userId": {
        ".read": "auth != null && auth.uid === $userId",
        ".write": "auth != null && auth.uid === $userId"
      }
    }
  }
}




